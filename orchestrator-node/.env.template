# Social Media Content Orchestrator - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# SUPABASE DATABASE
# =============================================================================

# Supabase project URL (https://supabase.com)
SUPABASE_URL=

# Supabase anonymous key (safe to use in browser)
SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, has admin access)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# NEWS SOURCES
# =============================================================================

# NewsAPI - For fetching news articles (https://newsapi.org)
# Free tier: 100 requests/day
NEWSAPI_KEY=

# Reddit API - For fetching trending topics (https://www.reddit.com/prefs/apps)
# Optional - public endpoints work without authentication
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# =============================================================================
# CONTENT GENERATION (LLMs)
# =============================================================================

# OpenAI API - For GPT-4 and DALL-E 3 (https://platform.openai.com)
OPENAI_API_KEY=

# Anthropic API - For Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Stability AI - For Stable Diffusion (https://platform.stability.ai)
STABILITY_API_KEY=

# =============================================================================
# SOCIAL MEDIA PLATFORMS
# =============================================================================

# Twitter/X API (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# LinkedIn API (https://developer.linkedin.com)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Instagram API via Facebook Graph API (https://developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# Facebook API (https://developers.facebook.com)
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# =============================================================================
# ORCHESTRATOR SETTINGS
# =============================================================================

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Logging directory
LOG_DIR=logs

# Run in dry-run mode by default (true/false)
DRY_RUN=false

# Require approval for posts before publishing (true/false)
REQUIRE_APPROVAL=false
