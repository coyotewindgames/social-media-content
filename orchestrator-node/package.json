{
  "name": "social-media-orchestrator",
  "version": "1.0.0",
  "description": "A production-ready Node.js system for automated social media content generation and publishing using specialized AI agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "orchestrator": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/main.ts",
    "serve": "ts-node src/server.ts",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "social-media",
    "content-generation",
    "ai",
    "orchestrator",
    "automation",
    "twitter",
    "linkedin",
    "instagram",
    "facebook",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "node-cron": "^4.0.7",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.23",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
