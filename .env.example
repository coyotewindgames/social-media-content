# Social Media Content Orchestrator - Deployment Environment
# Copy to .env and fill in your values

# =============================================================================
# REQUIRED: Supabase Database
# =============================================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# REQUIRED: At least one LLM provider
# =============================================================================

# Ollama (self-hosted, runs as Docker service — no key needed)
# OLLAMA_ENDPOINT is set automatically in docker-compose.yml
OLLAMA_MODEL=llama3.2

# OpenAI (optional, for GPT-4 / DALL-E 3)
OPENAI_API_KEY=

# Anthropic (optional, for Claude)
ANTHROPIC_API_KEY=

# =============================================================================
# News Sources
# =============================================================================
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# =============================================================================
# Social Media Platforms (add keys for platforms you want to publish to)
# =============================================================================

# Twitter/X
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Instagram (via Facebook Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# Facebook
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# =============================================================================
# Image Generation
# =============================================================================

# xAI / Grok (primary — https://console.x.ai)
XAI_API_KEY=

# Stability AI (fallback — https://platform.stability.ai)
STABILITY_API_KEY=

# =============================================================================
# Server Settings
# =============================================================================
API_PORT=3001
LOG_LEVEL=info
LOG_DIR=logs
DRY_RUN=false
REQUIRE_APPROVAL=false

# =============================================================================
# Caddy / Domain (set your domain for auto-HTTPS)
# =============================================================================
DOMAIN=localhost
